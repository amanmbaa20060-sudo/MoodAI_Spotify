DATABASE_URL=postgresql://app:app@localhost:5432/discovery
REDIS_URL=redis://localhost:6379
DATASET_VERSION=v1.1.0
EXCEL_SOURCE_PATH=data/source/Music_Data.csv
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Phase 3 production (Render sets these via render.yaml)
# Local dev UI port (default 8010 — avoid 8000 if another app uses it)
MOODAI_PORT=8010
SMART_MOOD_DEFAULT_ENABLED=false
HOME_CACHE_TTL_SECONDS=60
ADAPTIVE_DROP_SIZE=10
DROP_PARTITIONS=4
LLM_TOKEN_BUDGET_PER_DAY=5000
MOOD_GATEWAY_ENABLED=true
VISUAL_SEARCH_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=false
